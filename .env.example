# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Model used for the deep-research phase (web search + reasoning). Defaults to Opus 4.8.
# Can be overridden per-request from the UI/CLI (--model); this is just the fallback default.
ANTHROPIC_RESEARCH_MODEL=claude-opus-4-8
# Model used for the cheaper structuring phase (turns the research memo into a brief). Defaults to Sonnet 5.
ANTHROPIC_BRIEF_MODEL=claude-sonnet-5

# Max output tokens per phase. Can be overridden per-request from the UI/CLI. Raise these if you
# see "cut off at max_tokens" errors on complex/long research; lower them to cap cost per lead.
ANTHROPIC_RESEARCH_MAX_TOKENS=24000
ANTHROPIC_BRIEF_MAX_TOKENS=8000

# Web server port
PORT=4000

# User-Agent used when fetching a prospect's own website to find their legal/registration page.
SCRAPER_USER_AGENT=Mozilla/5.0 (compatible; ExemplarSalesAgent/1.0; +https://exemplar.dk)
